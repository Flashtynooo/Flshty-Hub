-- Utilisation autorisée.
-- Modification et redistribution interdites.


return function(Window)


	local Home = Window.Home


	local SettingsPage = Instance.new("Frame")
	SettingsPage.Name = "Settings"
	SettingsPage.Size = UDim2.new(1,0,1,0)
	SettingsPage.BackgroundTransparency = 1
	SettingsPage.Visible = false
	SettingsPage.Parent = Home



	local Title = Instance.new("TextLabel")
	Title.Name = "SettingsTitle"
	Title.Size = UDim2.new(1,0,0,35)
	Title.BackgroundTransparency = 1
	Title.Text = "Paramètres"
	Title.TextColor3 = Color3.fromRGB(255,255,255)
	Title.TextSize = 20
	Title.Font = Enum.Font.GothamBold
	Title.Parent = SettingsPage



	local Scroll = Instance.new("ScrollingFrame")
	Scroll.Name = "SettingsScroll"
	Scroll.Position = UDim2.new(0,10,0,45)
	Scroll.Size = UDim2.new(1,-20,1,-55)
	Scroll.BackgroundColor3 = Color3.fromRGB(15,15,20)
	Scroll.BackgroundTransparency = 0.2
	Scroll.ScrollBarThickness = 4
	Scroll.CanvasSize = UDim2.new(0,0,0,100)
	Scroll.Parent = SettingsPage



	local Corner = Instance.new("UICorner")
	Corner.CornerRadius = UDim.new(0,10)
	Corner.Parent = Scroll



	local Text = Instance.new("TextLabel")
	Text.Size = UDim2.new(1,0,0,40)
	Text.BackgroundTransparency = 1
	Text.Text = "Flshty Settings"
	Text.TextColor3 = Color3.fromRGB(220,220,220)
	Text.TextSize = 16
	Text.Parent = Scroll



	-- Référence bouton paramètres

	local SettingsButton = Window.SettingsButton



	if SettingsButton then


		SettingsButton.MouseButton1Click:Connect(function()


			if SettingsPage.Visible then

				-- Fermer paramètres

				SettingsPage.Visible = false


				if Window.CurrentCategory then
					Window.CurrentCategory.Visible = true
				end


			else

				-- Ouvrir paramètres

				if Window.CurrentCategory then
					Window.CurrentCategory.Visible = false
				end


				SettingsPage.Visible = true


			end


		end)


	end



end
