local Flshty = {}

Flshty.__index = Flshty


Flshty.Theme = {
	Background = Color3.fromRGB(10,10,15),
	TopBar = Color3.fromRGB(20,10,30),
	Purple = Color3.fromRGB(130,0,255),
	Pink = Color3.fromRGB(255,0,170),
	Text = Color3.fromRGB(255,255,255)
}



local CategoriesURL = "https://raw.githubusercontent.com/Flashtynooo/Flshty-Hub/refs/heads/main/8zhzgdi7zveod8zh3veusrzhe9jdbe8zueh-categories"



function Flshty:CreateWindow(options)


	options = options or {}


	local Window = {}

	Window.__index = Window

	setmetatable(Window,Flshty)



	local CoreGui = game:GetService("CoreGui")



	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "Flshty"
	ScreenGui.Parent = CoreGui



	local MainFrame = Instance.new("Frame")
	MainFrame.Name = "Window"
	MainFrame.Size = UDim2.new(0,450,0,300)
	MainFrame.Position = UDim2.new(0.5,-225,0.5,-150)
	MainFrame.BackgroundColor3 = Flshty.Theme.Background
	MainFrame.BackgroundTransparency = 0.2
	MainFrame.Parent = ScreenGui


	local Corner = Instance.new("UICorner")
	Corner.CornerRadius = UDim.new(0,14)
	Corner.Parent = MainFrame


	local Stroke = Instance.new("UIStroke")
	Stroke.Thickness = 3
	Stroke.Color = Flshty.Theme.Pink
	Stroke.Parent = MainFrame



	local TopBar = Instance.new("Frame")
	TopBar.Name = "TopBar"
	TopBar.Size = UDim2.new(1,0,0,40)
	TopBar.BackgroundColor3 = Flshty.Theme.TopBar
	TopBar.Parent = MainFrame



	local Title = Instance.new("TextLabel")
	Title.Size = UDim2.new(1,-100,1,0)
	Title.Position = UDim2.new(0,15,0,0)
	Title.BackgroundTransparency = 1
	Title.Text = options.Name or "Flshty"
	Title.TextColor3 = Flshty.Theme.Text
	Title.TextSize = 18
	Title.Font = Enum.Font.GothamBold
	Title.Parent = TopBar



	local Minimize = Instance.new("TextButton")
	Minimize.Size = UDim2.new(0,40,0,40)
	Minimize.Position = UDim2.new(1,-80,0,0)
	Minimize.BackgroundTransparency = 1
	Minimize.Text = "─"
	Minimize.TextSize = 25
	Minimize.TextColor3 = Flshty.Theme.Text
	Minimize.Parent = TopBar



	local Settings = Instance.new("TextButton")
	Settings.Size = UDim2.new(0,40,0,40)
	Settings.Position = UDim2.new(1,-40,0,0)
	Settings.BackgroundTransparency = 1
	Settings.Text = "⚙️"
	Settings.TextSize = 28
	Settings.TextColor3 = Flshty.Theme.Text
	Settings.Parent = TopBar



	local Home = Instance.new("Frame")
	Home.Name = "Home"
	Home.Size = UDim2.new(1,0,1,-40)
	Home.Position = UDim2.new(0,0,0,40)
	Home.BackgroundTransparency = 1
	Home.Parent = MainFrame



	-- PARAMETRES DIRECTEMENT DANS HOME

	local SettingsPage = Instance.new("Frame")
	SettingsPage.Name = "Settings"
	SettingsPage.Size = UDim2.new(1,0,1,0)
	SettingsPage.BackgroundTransparency = 1
	SettingsPage.Visible = false
	SettingsPage.Parent = Home



	local SettingsTitle = Instance.new("TextLabel")
	SettingsTitle.Size = UDim2.new(1,0,0,40)
	SettingsTitle.BackgroundTransparency = 1
	SettingsTitle.Text = "Paramètres"
	SettingsTitle.TextColor3 = Flshty.Theme.Text
	SettingsTitle.TextSize = 20
	SettingsTitle.Font = Enum.Font.GothamBold
	SettingsTitle.Parent = SettingsPage



	local Floating = Instance.new("TextButton")
	Floating.Name = "FlshtyButton"
	Floating.Size = UDim2.new(0,80,0,40)
	Floating.Position = UDim2.new(0,20,0.5,0)
	Floating.BackgroundColor3 = Flshty.Theme.Background
	Floating.Text = "Flshty"
	Floating.TextColor3 = Flshty.Theme.Text
	Floating.Visible = false
	Floating.Parent = ScreenGui



	-- Bouton paramètres

	Settings.MouseButton1Click:Connect(function()


		if SettingsPage.Visible then

			SettingsPage.Visible = false

			if Window.CurrentCategory then
				Window.CurrentCategory.Visible = true
			end


		else

			if Window.CurrentCategory then
				Window.CurrentCategory.Visible = false
			end

			SettingsPage.Visible = true

		end


	end)



	Minimize.MouseButton1Click:Connect(function()

		MainFrame.Visible = false
		Floating.Visible = true

	end)



	Floating.MouseButton1Click:Connect(function()

		MainFrame.Visible = true
		Floating.Visible = false

	end)



	Window.Gui = ScreenGui
	Window.Frame = MainFrame
	Window.Home = Home
	Window.SettingsButton = Settings
	Window.SettingsPage = SettingsPage
	Window.FloatingButton = Floating
	Window.CurrentCategory = nil



	-- Chargement catégories

	local CategoriesLoader = loadstring(game:HttpGet(CategoriesURL))

	if CategoriesLoader then
		CategoriesLoader()(Window)
	end



	return Window

end


return Flshty
